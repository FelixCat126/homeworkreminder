.page {
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: var(--bg); /* 使用浅色背景 */
  display: flex;
  flex-direction: column;
}

.hero-image-wrap {
  width: 100%;
  flex-shrink: 0;
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 图片区域可以根据需要调整高度占比，或者自适应图片高度 */
}

.hero-image {
  width: 100%;
  display: block;
}

.content-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 60rpx 40rpx;
  background: var(--bg);
  position: relative;
  z-index: 2;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1); /* 上阴影，增加层次感 */
  border-radius: 40rpx 40rpx 0 0; /* 顶部圆角 */
  margin-top: -30rpx; /* 稍微向上覆盖一点图片 */
}

.title-box {
  background: var(--accent);
  padding: 16rpx 48rpx;
  border: var(--border-width) solid var(--dark);
  border-radius: 60rpx;
  box-shadow: 4rpx 4rpx 0 var(--dark);
  margin-bottom: 24rpx;
  animation: slideUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

.slogan {
  font-size: 48rpx;
  font-weight: 900;
  color: var(--dark);
  letter-spacing: 4rpx;
}

.sub {
  font-size: 36rpx;
  color: var(--dark);
  font-weight: 900;
  margin-bottom: 48rpx;
  opacity: 0.8;
  animation: fadeIn 0.8s 0.3s both;
  letter-spacing: 2rpx;
}

/* 鼓励语卡片 */
.quote-box {
  background: #FFF;
  border: var(--border-width) solid var(--dark);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 60rpx;
  width: 100%;
  box-shadow: 6rpx 6rpx 0 var(--dark);
  animation: fadeIn 0.8s 0.5s both;
  transform: rotate(-1deg);
}

.quote-text {
  display: block;
  font-size: 32rpx;
  color: var(--dark);
  font-weight: 700;
  line-height: 1.6;
  text-align: center;
  font-style: italic;
}

.btn-group {
  width: 100%;
  display: flex;
  justify-content: center;
  animation: fadeIn 0.8s 0.7s both;
}

.btn-game {
  background: var(--primary);
  color: #fff;
  font-weight: 900;
  padding: 24rpx 80rpx;
  border: var(--border-width) solid var(--dark);
  border-radius: 60rpx;
  box-shadow: 4rpx 4rpx 0 var(--dark);
  font-size: 32rpx;
  transition: all 0.2s;
}

.btn-game:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 var(--dark);
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 纸屑动画 */
.confetti-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 3;
}

.confetti-dot {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  top: -20rpx;
  border-radius: 50%;
  opacity: 0.8;
  animation: confettiFall 4s linear infinite;
}

@keyframes confettiFall {
  0% { transform: translateY(-20rpx) rotate(0deg); }
  100% { transform: translateY(100vh) rotate(360deg); }
}
