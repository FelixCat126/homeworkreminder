.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  padding: 40rpx;
  /* 点阵背景 */
  background-image: linear-gradient(0deg, #E1E1E1 1px, transparent 1px),
  linear-gradient(90deg, #E1E1E1 1px, transparent 1px);
  background-size: 24rpx 24rpx;
}

.timer-container {
  margin-bottom: 100rpx;
  position: relative;
}

.timer-circle {
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  border: 12rpx solid var(--dark);
  background: #FFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow);
  position: relative;
}

/* 装饰性外圈 */
.timer-circle::after {
  content: '';
  position: absolute;
  top: -24rpx;
  left: -24rpx;
  right: -24rpx;
  bottom: -24rpx;
  border: 4rpx dashed var(--primary);
  border-radius: 50%;
  animation: spin 10s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.timer-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

.timer-label {
  font-size: 28rpx;
  color: #636e72;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.timer-value {
  font-size: 100rpx;
  font-weight: 900;
  color: var(--dark);
  font-family: monospace;
  letter-spacing: 4rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.task-title {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 900;
  max-width: 400rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding: 8rpx 24rpx;
  background: rgba(108, 92, 231, 0.1);
  border-radius: 32rpx;
}

.controls {
  display: flex;
  gap: 40rpx;
  width: 100%;
  justify-content: center;
}

.btn-control {
  width: 240rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: var(--border-width) solid var(--dark);
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: 900;
  box-shadow: var(--shadow);
  transition: all 0.1s;
}

.btn-control:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: var(--shadow-active);
}

.pause {
  background: var(--light);
  color: var(--dark);
}

.complete {
  background: var(--accent);
  color: var(--dark);
}

/* 漫画风格弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  width: 600rpx;
  background: var(--light);
  border: var(--border-width) solid var(--dark);
  border-radius: var(--radius);
  box-shadow: 16rpx 16rpx 0 var(--dark);
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--dark);
  margin-bottom: 40rpx;
  text-transform: uppercase;
}

.modal-body {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  width: 100%;
}

.modal-label {
  font-size: 32rpx;
  font-weight: 800;
  margin-right: 20rpx;
}

.modal-input {
  width: 160rpx;
  height: 80rpx;
  background: #fff;
  border: var(--border-width) solid var(--dark);
  border-radius: 16rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: 900;
  color: var(--primary);
  margin-right: 20rpx;
}

.modal-unit {
  font-size: 32rpx;
  font-weight: 800;
}

.modal-footer {
  display: flex;
  gap: 30rpx;
  width: 100%;
  justify-content: center;
}

.btn-modal {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: var(--border-width) solid var(--dark);
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 6rpx 6rpx 0 var(--dark);
  transition: all 0.1s;
}

.btn-modal:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 2rpx 2rpx 0 var(--dark);
}

.btn-cancel {
  background: #fff;
  color: var(--dark);
}

.btn-confirm {
  background: var(--primary);
  color: #fff;
}